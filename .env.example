# =========================================
# carteiraexpert — Variáveis de ambiente
# Copie para .env e preencha os valores reais
# =========================================

# Banco de dados (obrigatório)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Ambiente
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =========================================
# Cap 3 — Autenticação (deixe vazio por enquanto)
# =========================================
AUTH_SECRET=""
AUTH_URL=""

# =========================================
# Cap 6 — Provedores de dados financeiros
# (todos já validados em 22/07/2026)
# =========================================

# Brapi — cotações BR + dividendos BR (quote_br, dividend_br)
BRAPI_TOKEN=""

# Finnhub — cotações US + fundamentais US (quote_us, fundamental_us)
FINNHUB_TOKEN=""

# TwelveData — fallback cotações US (quote_us)
TWELVE_DATA_TOKEN=""

# Alpha Vantage — fallback cotações US (quote_us)
ALPHA_VANTAGE_TOKEN=""

# CoinGecko — cotações cripto (crypto, free tier funciona sem chave mas o demo key é mais estável)
COINGECKO_DEMO_API_KEY=""

# FMP — fallback fundamentais US profile (fundamental_us, opcional)
FMP_API_KEY=""

# SEC Edgar — fundamentais US via XBRL + dividendos US (fundamental_us, dividend_us)
# OBRIGATÓRIO pela SEC: User-Agent com email real
SEC_CONTACT_EMAIL="seu-email@dominio.com"

# =========================================
# Cap 9 — IA Anthropic (deixe vazio por enquanto)
# =========================================
ANTHROPIC_API_KEY=""

# =========================================
# Cap 16 — Operação (deixe vazio por enquanto)
# =========================================
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
RESEND_API_KEY=""